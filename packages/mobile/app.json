      "bundleIdentifier": "com.animaldaily.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F8FAFC"
      },
      "package": "com.animaldaily.app"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
