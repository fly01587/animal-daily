{
  "expo": {
    "name": "Animal Daily",
    "slug": "animal-daily",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "animal-daily",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#F8FAFC"
    },
